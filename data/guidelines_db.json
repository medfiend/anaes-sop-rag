    "clinical": {
      "title": "Dexmedetomidine Sedation SOP for Awake Fibreoptic Intubation",
      "steps": [
        {
          "step_number": 1,
          "text": "Dilute Dexmedetomidine 200mcg in 50ml 0.9% Sodium Chloride (final concentration 4mcg/ml)."
        },
        {
          "step_number": 2,
          "text": "Calculate loading dose of 1mcg/kg over 10 minutes based on Actual Weight (ABW) if BMI < 30, or Adjusted Weight (AdjBW) if BMI > 30."
        },
        {
          "step_number": 3,
          "text": "Set up Agilia infusion pump to run loading dose, followed by maintenance infusion of 0.2 - 0.7 mcg/kg/h titrated to Ramsay Sedation Score of 2 or 3."
        }
      ]
    },
