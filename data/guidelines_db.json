    "protocol_id": "malignant-hyperthermia",
    "status": "Active",
    "metadata": {
      "version_hash": "git_mock_mh_2024",
      "compiled_at": "2024-01-10T00:00:00Z",
      "review_due_at": "2027-01-10T00:00:00Z",
      "owner_email": "audit.lead@nhs.net",
      "supersedes_document_id": null
    },
    "clinical": {
      "title": "AAGBI Safety Guideline: Management of Malignant Hyperthermia",
      "steps": [
        {
          "step_number": 1,
          "text": "TRIGGER ACTION: Immediately stop all volatile anaesthetics and succinylcholine. Maintain anesthesia with IV agents (TIVA). Hyperventilate with 100% Oxygen at max flows (10-15 L/min)."
        },
        {
          "step_number": 2,
          "text": "ANTIDOTE THERAPY: Administer Dantrolene immediately. Reconstitute each vial with 60ml sterile water. Bolus 2.5 mg/kg IV. Repeat as needed up to 10 mg/kg until symptoms subside."
        },
        {
          "step_number": 3,
          "text": "ACTIVE COOLING: Infuse cold 0.9% saline IV. Ice packs to groin, axilla, and neck. Cease active cooling once core temperature drops below 38.5°C to avoid hypothermia."
        },
        {
          "step_number": 4,
          "text": "MONITOR & TREAT METABOLIC DERANGEMENTS: Treat hyperkalemia (Glucose/Insulin) and acidosis (Sodium Bicarbonate if pH < 7.2). Monitor arterial blood gases, urine output, and CK levels."
        }
      ]
    },
