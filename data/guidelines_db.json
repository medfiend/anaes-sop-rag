    "protocol_id": "paediatric-posterior-fossa",
    "status": "Active",
    "metadata": {
      "version_hash": "git_peds_pf_2025",
      "compiled_at": "2025-09-02T00:00:00Z",
      "review_due_at": "2028-09-02T00:00:00Z",
      "owner_email": "paeds.anesthesia@nhs.net",
      "supersedes_document_id": null
    },
    "clinical": {
      "title": "Paediatric Posterior Fossa Surgery Post-Operative Guideline",
      "steps": [
        {
          "step_number": 1,
          "text": "DAY ZERO (Immediate Post-Op): Paracetamol PO/IV. Omeprazole 10mg (10-19kg) or 20mg (20kg+). Ondansetron 0.1mg/kg IV TDS. Morphine infusion 5-40mcg/kg/hr if <30kg (or Morphine PCA if >30kg + background of 10-20mcg/kg/hr). Cyclizine IV TDS and Naloxone 100mcg/kg IV prn."
        },
        {
          "step_number": 2,
          "text": "DAY ONE (Transition & Neck Spasm): Continue Day Zero meds. Can start without neurosurgeon consult if child >12h post-op and neurologically appropriate: Ibuprofen max 30mg/kg/24h or Diclofenac 1mg/kg TDS (max 50mg). Diazepam for neck spasm PO (1-4 yrs: 1.25-2.5mg, 5-11 yrs: 2.5-5mg, 12+ yrs: 5-10mg). Movicol PO 1 sachet BD or Docusate Sodium 2-11 yrs 12.5-25mg tds / 12-17 yrs 100mg tds."
        },
        {
          "step_number": 3,
          "text": "DAY TWO - FOUR (Oral Transition): When ready to stop IV morphine: tolerating fluids, no vomiting, pain scores <=4/10. Established on oral paracetamol/ibuprofen. Dihydrocodeine 1mg/kg max 30mg (0.5mg/kg in children <4) or Oromorph 200mcg/kg 4 hourly prn. Laxatives if no bowel movement by Day 3."
        }
      ]
    },
