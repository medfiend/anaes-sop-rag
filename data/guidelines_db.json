      "supersedes_document_id": null
    },
    "clinical": {
      "title": "Paediatric Emergency Intubation Checklist",
      "steps": [
        {
          "step_number": 1,
          "text": "PLAN AHEAD: Assess expected difficulty (anatomical or physiological). Confirm right team (ED Consultant 8021, Anaesthesia 6111, Paeds Bleep 8448, PICU 6890, ENT 6075). Brief child/parents."
        },
        {
          "step_number": 2,
          "text": "EQUIPMENT CHECK: Check monitoring (ETCO2, SpO2, NIBP, ECG). Prepare airway gear: Mask, OPA/NPA, laryngoscopes x2, ETT, Bougie (5 for ETT <3.5, 10 for ETT 4-5, 15 for ETT >6), LMA (1 for <5kg, 1.5 for 5-10kg, 2 for 10-20kg, 2.5 for 20-30kg, 3 for 30-50kg, 4 for >50kg), NGT and suction size (ETT ID x2)."
        },
        {
          "step_number": 3,
          "text": "PATIENT CHECK: Calculate WETFLAG. Verify IV access x 2. Ensure optimal physiology (pre-oxygenation 3 mins, fluid status). Optimize positioning (shoulder roll/pillow). Insert NGT."
        },
        {
          "step_number": 4,
          "text": "TEAM & CONFIRMATION: Confirm roles (Leader, Intubators, Airway assistant, Drugs). Review failure plan (Plans A-D, FONA, physiological collapse). Confirm success: ETCO2 x 6 waves, secure ETT, start ventilation/sedation."
        }
      ]
    },
    "site_logistics": {
