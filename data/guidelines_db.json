  {
    "protocol_id": "renal-transplant-guidelines",
    "status": "Active",
    "metadata": {
      "version_hash": "git_renal_trans_2023",
      "compiled_at": "2023-08-01T00:00:00Z",
      "review_due_at": "2025-10-01T00:00:00Z",
      "owner_email": "renal.anaesthesia@nhs.net",
      "supersedes_document_id": null
    },
    "clinical": {
      "title": "Renal Transplantation Anaesthetic Guidelines",
      "steps": [
        {
          "step_number": 1,
          "text": "PREPARATION: Review hydration state (post-dialysis hypovolaemia risk), K+/Ca++ levels, and clotting status (check anticoagulants plan). Check red cell requirements (Hb < 80 g/L needs transfusion). Consider RSI if high risk of aspiration."
        },
        {
          "step_number": 2,
          "text": "INTRAOPERATIVE MONITORING: Wrap existing AV fistulae loosely in gamgee; no BP cuff/drips on AV arm. Wrap arms loosely. Arterial line for high-risk patients. Goal-directed fluid therapy via ClearSight or FlowTrac recommended."
        },
        {
          "step_number": 3,
          "text": "INDUCTION & INTRAOP DRUGS: Propofol + fentanyl induction. Neuromuscular block: Atracurium or Rocuronium (Sugammadex reversal). AVOID suxamethonium. Target MAP more than 70-75mmHg (or not less than 20% below baseline). Give Methylprednisolone 500mg and Basiliximab 20mg before reperfusion (best after induction)."
        },
        {
          "step_number": 4,
