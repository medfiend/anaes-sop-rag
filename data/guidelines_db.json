    "protocol_id": "la-toxicity",
    "status": "Active",
    "metadata": {
      "version_hash": "git_last2023",
      "compiled_at": "2023-03-01T00:00:00Z",
      "review_due_at": "2026-03-01T00:00:00Z",
      "owner_email": "audit.lead@nhs.net",
      "supersedes_document_id": null
    },
    "clinical": {
      "title": "AAGBI Safety Guideline: Management of Local Anaesthetic Toxicity (LAST)",
      "steps": [
        {
          "step_number": 1,
          "text": "IMMEDIATE ACTION: Stop injecting local anaesthetic. Call for help (State: Local Anaesthetic Toxicity emergency). Maintain airway, hyperventilate with 100% Oxygen."
        },
        {
          "step_number": 2,
          "text": "SEIZURE CONTROL: Administer Benzodiazepines (e.g. Midazolam 1-2mg IV) or Thiopental. Avoid Propofol if cardiovascular instability is present."
        },
        {
          "step_number": 3,
          "text": "LIPID RESCUE THERAPY: Administer Intralipid 20% lipid emulsion:\n- IV Bolus: 1.5 ml/kg over 1 minute.\n- IV Infusion: Start at 15 ml/kg/h."
        },
        {
          "step_number": 4,
          "text": "CARDIOVASCULAR RESUSCITATION: If cardiac arrest occurs, start CPR. Avoid Vasopressin, Calcium channel blockers, and Lidocaine. Use small doses of Epinephrine (10-100mcg) if needed."
        }
      ]
    },
